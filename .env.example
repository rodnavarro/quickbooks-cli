# Copy to .env (gitignored) and fill in. Get credentials at https://developer.intuit.com
QBO_CLIENT_ID=
QBO_CLIENT_SECRET=
QBO_ENVIRONMENT=sandbox
# Optional: where to read/write the OAuth tokens file (defaults to ./qbo_tokens.json)
# QBO_TOKENS_FILE=/data/qbo_tokens.json
# Optional OAuth redirect (must match the URI registered in your Intuit app)
# QBO_REDIRECT=http://localhost:8000/callback
